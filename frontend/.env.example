# Frontend env (copy to .env and fill in for multi-user / cloud deploys).
# Leaving these blank keeps the app in single-user / localStorage mode.

# Supabase project — same project as the backend uses.
# Settings → API → URL
VITE_SUPABASE_URL=
# Settings → API → anon public key (safe to expose to the browser)
VITE_SUPABASE_ANON_KEY=
