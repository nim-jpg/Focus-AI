# Backend env (copy to .env, fill in values)
PORT=8787
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Google Calendar OAuth — required only for the Schedule button.
# Setup once:
#   1. Create a project at https://console.cloud.google.com/
#   2. APIs & Services → Library → enable "Google Calendar API"
#   3. APIs & Services → OAuth consent screen → External, add yourself as a test user
#   4. APIs & Services → Credentials → Create Credentials → OAuth client ID
#      - Application type: Web application
#      - Authorized redirect URI: http://localhost:8787/api/google/callback
#   5. Paste the client id + secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/google/callback
FRONTEND_URL=http://localhost:5173

# Companies House (UK) — required only for the Company Assist feature.
# Free key at https://developer.company-information.service.gov.uk/
# Register an "application" with type "Live", paste the API key here.
COMPANIES_HOUSE_API_KEY=
