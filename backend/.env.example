# Backend env (copy to .env, fill in values)
PORT=8787
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Google Calendar OAuth — required only for the Schedule button.
# Setup once:
#   1. Create a project at https://console.cloud.google.com/
#   2. APIs & Services → Library → enable "Google Calendar API"
#   3. APIs & Services → OAuth consent screen → External, add yourself as a test user
#   4. APIs & Services → Credentials → Create Credentials → OAuth client ID
#      - Application type: Web application
#      - Authorized redirect URI: http://localhost:8787/api/google/callback
#   5. Paste the client id + secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/google/callback
FRONTEND_URL=http://localhost:5173

# Companies House (UK) — required only for the Company Assist feature.
# Free key at https://developer.company-information.service.gov.uk/
# Register an "application" with type "Live", paste the API key here.
COMPANIES_HOUSE_API_KEY=

# Supabase (multi-user mode) — when set, the backend gates routes behind
# Supabase Auth and stores per-user data in Postgres. Leave blank to keep
# single-user / localStorage behaviour for local dev.
# 1. Create a project at https://supabase.com (free tier is fine)
# 2. Settings → API → URL goes in SUPABASE_URL
# 3. Settings → API → service_role key goes in SUPABASE_SERVICE_ROLE_KEY
#    (server-only; never expose this to the frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Allowed origins for CORS (comma-separated). For prod set this to your
# Vercel domain, e.g. https://focus3.app,https://www.focus3.app.
# Empty = wide open (fine for local dev).
ALLOWED_ORIGINS=
